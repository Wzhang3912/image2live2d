# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.env

# Tooling
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ML / model weights / data
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.gguf
*.h5
*.pb
*.tflite
models/
checkpoints/
data/
# ...except the test expectation tables, which are code. They describe the character corpus without
# containing any of it — the images themselves stay out of the repo (see tests/test_character_corpus.py).
!tests/data/
!tests/data/*.json

# Images / character art / other binary data (keep the repo code-only)
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.psd
*.psb
assets/

# Internal docs / planning notes (not part of the public package)
docs/

# Demo media referenced by the README (explicitly allowed past the image rules above)
!media/
!media/demo.gif
!media/cells/
!media/cells/*.gif

# Generated artifacts
out/
*.inp
*.inx
*.moc3
*.cmo3

# Pro Live2D model configs — copyrighted; used only as a LOCAL calibration corpus (see
# tools/calibrate_dynamics.py). Keep the repo code-only.
*.physics3.json
*.model3.json
*.cdi3.json
*.motion3.json
corpus/

# OS / editor
.DS_Store
.idea/
.vscode/
